// -----------------------------------------------------------------------------
// AWS HealthOmics execution profile
// HealthOmics manages compute — instance type is selected based on
// cpus + memory requested per process.
// Update resource values once Run Group vCPU/memory limits are confirmed.
// -----------------------------------------------------------------------------
docker.enabled = true

process {
    stageInMode = 'copy'

    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16 GB'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '32 GB'
    }
    withLabel: 'process_high_memory' {
        cpus   = 8
        memory = '64 GB'
    }
}
