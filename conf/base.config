// -----------------------------------------------------------------------------
// Default process resource labels
// Update withLabel blocks once Run Group limits are confirmed with client
// -----------------------------------------------------------------------------
process {
    cpus   = 2
    memory = '8 GB'

    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16 GB'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '32 GB'
    }
    withLabel: 'process_high_memory' {
        cpus   = 8
        memory = '64 GB'
    }

    // -------------------------------------------------------------------------
    // Container images
    // quay.io URIs are resolved via ECR pull-through cache at runtime
    // TODO: verify exact BioContainers tag hashes before first run
    // -------------------------------------------------------------------------
    withName: 'FASTQC' {
        container = 'quay.io/biocontainers/fastqc:0.12.0--hdfd78af_0'
    }
    withName: 'KNEADDATA' {
        container = 'quay.io/biocontainers/kneaddata:0.12.0--pyhdfd78af_0'
    }
    withName: 'METAPHLAN|MERGE_TAXONOMIC_PROFILES' {
        container = 'quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }
    withName: 'HUMANN.*' {
        container = 'quay.io/biocontainers/humann:3.9--py312hdfd78af_0'
    }
    withName: 'MULTIQC' {
        container = 'quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0'
    }
}
