nextflow.enable.dsl = 2

params {
    // -------------------------------------------------------------------------
    // Input / output  (S3 paths)
    // -------------------------------------------------------------------------
    input          = null   // e.g. "s3://bucket/input/**/*_{1,2}.fastq.gz"
    output         = null   // e.g. "s3://bucket/output/"
    outdir         = '/mnt/workflow/pubdir'

    // -------------------------------------------------------------------------
    // Databases  (S3 paths — fill in once confirmed with client)
    // -------------------------------------------------------------------------
    kneaddata_db   = null   // s3://.../databases/kneaddata/GRCh38/
    metaphlan_db   = null   // s3://.../databases/metaphlan/mpa_vJun23/  (contains mpa_vJan25_CHOCOPhlAnSGB_202503)
    humann_nt_db   = null   // s3://.../databases/humann/chocophlan/chocophlan/
    humann_prot_db = null   // s3://.../databases/humann/uniref/  (update path after UniRef extraction)
    humann_map_db  = null   // s3://.../databases/humann/metacyc/utility_mapping/

    // -------------------------------------------------------------------------
    // KneadData / Trimmomatic settings
    // -------------------------------------------------------------------------
    trimmomatic_options = [
        'ILLUMINACLIP:TruSeq3-PE.fa:2:30:10:2:True',
        'LEADING:3',
        'TRAILING:3',
        'SLIDINGWINDOW:4:20',
        'MINLEN:70'
    ].join(' ')

    // -------------------------------------------------------------------------
    // MetaPhlAn settings
    // -------------------------------------------------------------------------
    metaphlan_db_version = 'mpa_vJan25_CHOCOPhlAnSGB_202503'

    // -------------------------------------------------------------------------
    // Optional steps
    // -------------------------------------------------------------------------
    run_strainphlan = false

    // -------------------------------------------------------------------------
    // MultiQC
    // -------------------------------------------------------------------------
    multiqc_config = null
}

// -----------------------------------------------------------------------------
// Profiles
// -----------------------------------------------------------------------------
profiles {
    healthomics {
        includeConfig 'conf/healthomics.config'
    }
    local {
        process.executor = 'local'
        docker.enabled   = true
    }
}

includeConfig 'conf/base.config'
